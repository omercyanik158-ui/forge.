{
  "name": "yenispor",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:training-catalog": "python3 scripts/generate_training_catalog.py",
    "build:forge-workout-brain": "python3 scripts/generate_forge_workout_brain.py",
    "build:forge-workout-library-300": "python3 scripts/generate_forge_workout_library_300.py",
    "analyze:workout-dataset": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --max-old-space-size=8192 --experimental-strip-types scripts/analyze-workout-dataset.ts",
    "typecheck": "tsc --noEmit",
    "check:content": "node scripts/quality-check.mjs",
    "check:expo": "npx expo-doctor",
    "check:release": "node scripts/release-check.mjs",
    "check:release-config": "node scripts/check-release-config.mjs",
    "check:repo-hygiene": "node scripts/check-repository-hygiene.mjs",
    "lint": "eslint app src scripts --max-warnings=0",
    "test": "vitest run",
    "check:quality": "npm run typecheck && npm run lint && npm run test && npm run check:content && npm run check:expo"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@shopify/flash-list": "^2.0.2",
    "@supabase/supabase-js": "^2.110.2",
    "@upstash/redis": "^1.38.0",
    "expo": "^57.0.0",
    "expo-apple-authentication": "~57.0.0",
    "expo-application": "~57.0.0",
    "expo-auth-session": "~57.0.2",
    "expo-blur": "~57.0.0",
    "expo-camera": "~57.0.1",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-manipulator": "~57.0.2",
    "expo-image-picker": "~57.0.2",
    "expo-linking": "~57.0.2",
    "expo-localization": "~57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-sharing": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "posthog-react-native": "^4.55.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-google-mobile-ads": "^16.4.0",
    "react-native-purchases": "^10.4.2",
    "react-native-reanimated": "^4.5.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-view-shot": "^5.1.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.10.0"
