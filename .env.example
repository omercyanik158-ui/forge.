# Forge environment contract
# Do not put server-only secrets into EXPO_PUBLIC_* variables.
# Real values belong in local env files or CI secrets, not in git.

## Client-public values

# Required in all client runtimes
EXPO_PUBLIC_APP_ENV=development

# Required for production, optional for development/test
EXPO_PUBLIC_TEMPLATE_PROGRAM_ENGINE=false
EXPO_PUBLIC_PROGRESSION_WRITES=false
EXPO_PUBLIC_PHYSIQUE_ADAPTATION_WRITES=false

# Optional development overrides
EXPO_PUBLIC_TEMPLATE_PROGRAM_ENGINE_DEV_OVERRIDE=false
EXPO_PUBLIC_PROGRESSION_WRITES_DEV_OVERRIDE=false
EXPO_PUBLIC_PHYSIQUE_ADAPTATION_DEV_OVERRIDE=false

# Purchases
# Required for production mobile releases
EXPO_PUBLIC_PURCHASES_ENABLED=false
EXPO_PUBLIC_RC_IOS_API_KEY=rc_ios_public_sdk_key_placeholder
EXPO_PUBLIC_RC_ANDROID_API_KEY=rc_android_public_sdk_key_placeholder

# Optional RevenueCat identifiers
EXPO_PUBLIC_RC_ENTITLEMENT_ID=premium
EXPO_PUBLIC_RC_OFFERING_ID=default
EXPO_PUBLIC_RC_MONTHLY_PACKAGE_ID=$rc_monthly
EXPO_PUBLIC_RC_ANNUAL_PACKAGE_ID=$rc_annual
EXPO_PUBLIC_RC_MONTHLY_PRODUCT_ID=forge_monthly
EXPO_PUBLIC_RC_ANNUAL_PRODUCT_ID=forge_yearly

# AI backend URL
# Required for preview/production when AI Hub is expected to work
EXPO_PUBLIC_AI_API_URL=http://localhost:3000

# Legal and support
# Required for production
EXPO_PUBLIC_PRIVACY_URL=https://example.com/privacy
EXPO_PUBLIC_TERMS_URL=https://example.com/terms
EXPO_PUBLIC_SUPPORT_EMAIL=support@example.com

# Optional analytics
EXPO_PUBLIC_ANALYTICS_ENABLED=false
EXPO_PUBLIC_POSTHOG_KEY=posthog_public_key_placeholder
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Optional AdMob / rewarded ads
EXPO_PUBLIC_ADMOB_ENABLED=false
EXPO_PUBLIC_ADMOB_TEST_MODE=true
EXPO_PUBLIC_ADMOB_IOS_APP_ID=admob_ios_app_id_placeholder
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=admob_android_app_id_placeholder
EXPO_PUBLIC_ADMOB_IOS_REWARDED_MEAL_AD_UNIT_ID=admob_ios_rewarded_meal_placeholder
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_MEAL_AD_UNIT_ID=admob_android_rewarded_meal_placeholder
EXPO_PUBLIC_ADMOB_IOS_REWARDED_PHYSIQUE_AD_UNIT_ID=admob_ios_rewarded_physique_placeholder
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_PHYSIQUE_AD_UNIT_ID=admob_android_rewarded_physique_placeholder

# Optional integrations
EXPO_PUBLIC_SUPABASE_URL=https://example.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=supabase_anon_key_placeholder
EXPO_PUBLIC_IMAGE_SEARCH_API_URL=https://example.com/image-search
EXPO_PUBLIC_PEXELS_KEY=pexels_public_key_placeholder

## Server-only values

# Required for server deploys
GEMINI_API_KEY=gemini_server_secret_placeholder
REVENUECAT_SECRET_API_KEY=revenuecat_server_secret_placeholder
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=upstash_server_token_placeholder

# Optional server tuning
GEMINI_MODEL=gemini-2.5-flash
